# Local dev stack (docker-compose.dev.yml)
#
# Quick start:
#   cp .env.local.example .env
#   docker compose -f docker-compose.dev.yml --env-file .env up -d
#
# The compose file fixes the Docker network name to `gopedia-dev` so E2E scripts can use:
#   export DOCKER_NETWORK_EXTERNAL=gopedia-dev

# --- Required for compose.dev (postgres + app) ---
POSTGRES_USER=admin_gopedia
POSTGRES_PASSWORD=changeme_local_only
OPENAI_API_KEY=

# --- Hosts: inside Docker network (default) ---
# Use these when Gopedia / ingestion containers attach to `gopedia-dev` (same as service names).
POSTGRES_HOST=postgres_db
POSTGRES_PORT=5432
POSTGRES_DB=gopedia
POSTGRES_SSLMODE=disable

TYPEDB_HOST=typedb
TYPEDB_PORT=1729
TYPEDB_DATABASE=gopedia
TYPEDB_USERNAME=admin
TYPEDB_PASSWORD=password

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Unify collection name (compose + DBInitializer + E2E scripts) ---
# Main docker-compose.yml defaults to gopedia_markdown; many scripts default to gopedia.
# Pick one value everywhere for local dev.
QDRANT_COLLECTION=gopedia_markdown
QDRANT_DOC_COLLECTION=gopedia_document

# --- E2E / docker run scripts ---
DOCKER_NETWORK_EXTERNAL=gopedia-dev

# Optional: override TypeDB image (must match typedb-driver in requirements.txt)
# TYPEDB_IMAGE=typedb/typedb:3.8.2

# =============================================================================
# Running API / tools on the host (not inside gopedia-dev)
# =============================================================================
# Publish ports are defaults: Postgres 5432, Qdrant 6333/6334, TypeDB 1729/8000.
# If you run `go run` or Python on the host against mapped ports, switch hosts to:
# POSTGRES_HOST=127.0.0.1
# TYPEDB_HOST=127.0.0.1
# QDRANT_HOST=127.0.0.1
# Do not set DOCKER_NETWORK_EXTERNAL for scripts that must run in a container on gopedia-dev.
#
# `./gopedia server` on the host: if POSTGRES_HOST is still `postgres_db`, the API remaps to
# 127.0.0.1 automatically (Docker DNS is unavailable on the host). Override dial host with:
# GOPEDIA_POSTGRES_HOST=127.0.0.1
#
# Same idea for Qdrant / TypeDB when .env still has compose names (`qdrant`, `typedb`):
# GOPEDIA_QDRANT_HOST=127.0.0.1
# GOPEDIA_TYPEDB_HOST=127.0.0.1
