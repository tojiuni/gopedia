define
  attribute doc_id, value string;
  attribute title, value string;
  attribute section_id, value string;
  attribute toc_level, value integer;
  attribute body, value string;

  entity document,
    owns doc_id,
    owns title;

  entity section,
    owns section_id,
    owns toc_level,
    owns body;

  relation composition,
    relates parent,
    relates child;

  document plays composition:parent;
  section plays composition:child,
    plays composition:parent;
