# =============================================================================
# Gopedia 4.1.1 (Markdown Origin) — Example env. Copy to .env and fill values.
# =============================================================================

# --- 2.1 Application / Service ---
GOPEDIA_SERVICE_NAME=
GOPEDIA_LOG_LEVEL=
GOPEDIA_MARKDOWN_WORKER_ID=

# --- 2.2 Identity-so (Machine ID) ---
GOPEDIA_IDENTITY_WORKER_ID=

# --- 2.3 PostgreSQL (Rhizome — master meta, machine registry) ---
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_SSLMODE=

# --- 2.4 TypeDB (Rhizome — graph, ontology) ---
TYPEDB_HOST=
TYPEDB_PORT=
TYPEDB_DATABASE=

# --- 2.5 Qdrant (Rhizome — vector) ---
QDRANT_HOST=
QDRANT_PORT=
QDRANT_COLLECTION=
QDRANT_VECTOR_SIZE=
QDRANT_GRPC_PORT=

# --- 2.6 Embedding ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=

# --- 2.7 Secrets / Common (morphso) ---
INFISICAL_HOST=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT_SLUG=
INFISICAL_TOKEN=

# --- 2.8 Docker / Network ---
DOCKER_NETWORK_EXTERNAL=
COMPOSE_PROJECT_NAME=
GOPEDIA_HOST_IP=
