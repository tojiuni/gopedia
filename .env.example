# =your_value_here
# Gopedia Sub-phase 0.0.1 (Markdown Origin) — Environment variables
# Ref: project_skills/wiki/universitas/gopedia/skills/gopedia-verify-flow/gopedia-markdown-origin/SKILL.md
# =your_value_here

# -----------------------------------------------------------------------------
# 2.1 Application / Service
# -----------------------------------------------------------------------------
# Service identifier (docker/compose logs)
GOPEDIA_SERVICE_NAME=your_value_here
# Log level: debug | info | warn | error
GOPEDIA_LOG_LEVEL=your_value_here
# Identity-so 64-bit ID: Worker ID (0~N). Use 0 for single worker.
GOPEDIA_MARKDOWN_WORKER_ID=your_value_here

# -----------------------------------------------------------------------------
# 2.2 Identity-so (Machine ID)
# -----------------------------------------------------------------------------
# Worker number for Machine ID; same value ensures same ID for all records from one file
GOPEDIA_IDENTITY_WORKER_ID=your_value_here

# -----------------------------------------------------------------------------
# 2.3 PostgreSQL (Rhizome — master meta, machine registry)
# Fill after DB is installed. Password: use INFISICAL or vault, do not commit.
# -----------------------------------------------------------------------------
POSTGRES_HOST=your_value_here
POSTGRES_PORT=your_value_here
POSTGRES_USER=your_value_here
POSTGRES_PASSWORD=your_value_here
POSTGRES_DB=your_value_here
POSTGRES_SSLMODE=your_value_here

# -----------------------------------------------------------------------------
# 2.4 TypeDB (Rhizome — graph, ontology Document/Section)
# Fill after DB is installed.
# -----------------------------------------------------------------------------
TYPEDB_HOST=your_value_here
TYPEDB_PORT=your_value_here
TYPEDB_DATABASE=your_value_here

# -----------------------------------------------------------------------------
# 2.5 Qdrant (Rhizome — vector, L1/L2/L3 embeddings)
# Fill after DB is installed. vector_size 1536 per OpenAI / SKILL.
# -----------------------------------------------------------------------------
QDRANT_HOST=your_value_here
QDRANT_PORT=your_value_here
QDRANT_COLLECTION=your_value_here
QDRANT_VECTOR_SIZE=your_value_here
QDRANT_GRPC_PORT=your_value_here
QDRANT_VECTOR_NAME=your_value_here
QDRANT_DOC_COLLECTION=your_value_here
QDRANT_DOC_VECTOR_NAME=your_value_here
QDRANT_DOC_VECTOR_SIZE=your_value_here

# -----------------------------------------------------------------------------
# 2.6 Embedding (OpenAI etc.)
# API key: use secret manager; e.g. ${INFISICAL_PATH/OPENAI_API_KEY}
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_value_here
OPENAI_EMBEDDING_MODEL=your_value_here

# -----------------------------------------------------------------------------
# 2.7 Secrets / Common (morphso config)
# Ref: project_skills/wiki/morphso/references/config.md
# -----------------------------------------------------------------------------
INFISICAL_HOST=your_value_here
INFISICAL_PROJECT_ID=your_value_here
INFISICAL_ENVIRONMENT_SLUG=your_value_here
# INFISICAL_TOKEN=your_value_here

# -----------------------------------------------------------------------------
# 2.8 Docker / Network (docker compose)
# neunexus: macvlan, subnet 192.168.0.0/24, gateway 192.168.0.1
# Ref: project_skills/wiki/universitas/neunexus/skills/docker-network/SKILL.md
# -----------------------------------------------------------------------------
DOCKER_NETWORK_EXTERNAL=your_value_here
COMPOSE_PROJECT_NAME=your_value_here
REGISTRY_SUBDOMAIN=your_value_here
DOMAIN=your_value_here
REGISTRY_USER_NAME=your_value_here
REGISTRY_USER_PASSWORD=your_value_here
# Optional: static IP on macvlan (use an unused IP in 192.168.0.0/24)
# GOPEDIA_HOST_IP=your_value_here
