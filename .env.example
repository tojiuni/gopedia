# Gopedia — copy to .env and adjust:
#   cp .env.example .env
#
# Local dev (Postgres + TypeDB + Qdrant on one network, no neunexus):
#   See .env.local.example and docker-compose.dev.yml; doc: doc/local-dev-docker.md
#
# docker compose (app):  docker compose --env-file .env up -d
#   Requires external Docker networks: neunexus, traefik-net (see docker-compose.yml).
#
# E2E / ingestion scripts (scripts/run_fresh_ingestion_docker.sh, etc.):
#   Containers must attach to the same network as postgres_db, typedb, qdrant.
#   Set DOCKER_NETWORK_EXTERNAL to that network name (default below: neunexus).

# =============================================================================
# Required for docker-compose.yml (no defaults for secrets)
# =============================================================================
POSTGRES_USER=
POSTGRES_PASSWORD=
OPENAI_API_KEY=

# =============================================================================
# Gopedia HTTP / Phloem (optional; compose sets listen addrs inside container)
# =============================================================================
# GOPEDIA_SERVICE_NAME=gopedia
# GOPEDIA_LOG_LEVEL=info
# GOPEDIA_IDENTITY_WORKER_ID=0
# GOPEDIA_MARKDOWN_WORKER_ID=0
# GOPEDIA_REPO_ROOT=/app
# Client → Phloem (host:port). Inside compose, Phloem listens on 0.0.0.0:50051.
# GOPEDIA_PHLOEM_GRPC_ADDR=localhost:50051

# =============================================================================
# PostgreSQL
# =============================================================================
# POSTGRES_HOST=postgres_db
# POSTGRES_PORT=5432
# POSTGRES_DB=gopedia
# POSTGRES_SSLMODE=disable

# =============================================================================
# TypeDB (DBInitializer / reset use TYPEDB_USERNAME / TYPEDB_PASSWORD)
# =============================================================================
# TYPEDB_HOST=typedb
# TYPEDB_PORT=1729
# TYPEDB_DATABASE=gopedia
# TYPEDB_USERNAME=admin
# TYPEDB_PASSWORD=password

# =============================================================================
# Qdrant
# =============================================================================
# HTTP REST and gRPC ports (Phloem often uses gRPC).
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333
# QDRANT_GRPC_PORT=6334
#
# Chunk / markdown collection name. docker-compose.yml defaults to gopedia_markdown;
# run_fresh_ingestion_docker.sh defaults to gopedia — use one value across stack + .env.
# QDRANT_COLLECTION=gopedia_markdown
#
# Document-level collection (reset_rhizome_docker.py, DBInitializer, verify scripts).
# QDRANT_DOC_COLLECTION=gopedia_document
# QDRANT_DOC_VECTOR_NAME=wiki
# QDRANT_DOC_VECTOR_SIZE=1536
#
# Leave empty so Phloem uses a single default unnamed vector (matches docker-compose).
# QDRANT_VECTOR_NAME=

# =============================================================================
# OpenAI
# =============================================================================
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Docker E2E / ingestion scripts (scripts/*.sh)
# =============================================================================
# Network where postgres_db, typedb, qdrant (and optional phloem-e2e) are reachable.
# DOCKER_NETWORK_EXTERNAL=neunexus
#
# Images (build: Dockerfile.ingestion vs project Dockerfile — see script headers).
# GOPEDIA_INGESTION_IMAGE=gopedia-ingestion:test
# GOPEDIA_PHLOEM_E2E_IMAGE=gopedia-phloem:e2e
# GOPEDIA_PHLOEM_E2E_NAME=phloem-e2e
#
# Alternate env file for run_project_ingestion_docker.sh
# GOPEDIA_ENV_FILE=.env

# =============================================================================
# Xylem verification (scripts/run_verify_xylem_docker.sh, verify_xylem_flow.py)
# =============================================================================
# GOPEDIA_RERANK=0
# Default keyword if not passed on CLI
# XYLEM_VERIFY_QUERY=Introduction

# =============================================================================
# Optional: Phloem sink / workers (see internal/phloem/sink)
# =============================================================================
# GOPEDIA_SOURCE_TYPE=md
# GOPEDIA_PROJECT_ID=
# GOPEDIA_NLP_WORKER_GRPC_ADDR=
